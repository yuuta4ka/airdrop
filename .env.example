TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Опционально: запасной список, если в админке chat ID не заданы.
# Предпочтительнее: Админка → Общие → Telegram-уведомления.
# TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# Persistent storage (Amvera: volume на /data). Локально можно не задавать —
# тогда используются site/data и site/assets/products.
# DATA_DIR=/data
# UPLOAD_DIR=/data/assets/products
